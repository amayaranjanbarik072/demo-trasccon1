{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
  // "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    //"outDir": "dist",
    "types": ["node", "@playwright/test"]
  },
  //"include": ["src", "tests", "playwright.config.ts"]
  "include": ["src/**/*.ts", "playwright.config.ts"]
}
